# =============================================================================
# .env.example (racine) — variables lues par docker-compose.
#
# Usage : copier ce fichier en `.env` (jamais versionné, voir .gitignore)
# puis remplacer les valeurs. Docker Compose lit automatiquement le fichier
# `.env` situé à côté du docker-compose.yml.
#
# Pourquoi ce mécanisme : le code et la configuration doivent être séparés
# (principe "12-factor app"). Le même code tourne en dev, en démo et chez
# chaque membre du trinôme avec des valeurs différentes, sans modification.
# =============================================================================
POSTGRES_PASSWORD=password

# Clé de signature JWT injectée dans le conteneur API.
# Générer la vôtre : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-only-change-me-in-env-2f8c1a94e7b3d6051c8f2ab47d9e0361
